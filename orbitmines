#!/usr/bin/env bash
set -uo pipefail

# ─────────────────────────────────────────────────────────────────────────────
# OrbitMines CLI
# ─────────────────────────────────────────────────────────────────────────────

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# ── Paths ────────────────────────────────────────────────────────────────────
SPIGOT_DIR="$SCRIPT_DIR/.orbitmines/spigot"
PLUGINS_DIR="$SCRIPT_DIR/.orbitmines/plugins"
SERVERS_DIR="$SCRIPT_DIR/.orbitmines/servers"
REMASTERED_DIR="$SCRIPT_DIR/@orbitmines/minecraft/remastered"
ARCHIVE_DIR="$SCRIPT_DIR/@orbitmines/minecraft/archive"
WORLDS_DIR="$ARCHIVE_DIR/worlds-test"
WORLDS_ZIP="$ARCHIVE_DIR/worlds-test.zip"
WORLDS_URL="https://archive.orbitmines.com/minecraft/worlds.zip"
WORLDS_EXPECTED_COUNT=461
WORLDS_ZIP_SIZE=40851743399

# ── Spigot config ───────────────────────────────────────────────────────────
BUNGEECORD_URL="https://ci.md-5.net/job/BungeeCord/lastSuccessfulBuild/artifact/bootstrap/target/BungeeCord.jar"
BUILDTOOLS_URL="https://hub.spigotmc.org/jenkins/job/BuildTools/lastSuccessfulBuild/artifact/target/BuildTools.jar"
SPIGOT_VERSIONS=("1.21.11")

# ── Theme ────────────────────────────────────────────────────────────────────
RST=$'\e[0m'
BOLD=$'\e[1m'
DIM=$'\e[2m'
ORANGE=$'\e[38;5;208m'
GRAY=$'\e[38;5;245m'
DARK=$'\e[38;5;240m'
WHITE=$'\e[38;5;255m'
RED=$'\e[38;5;203m'
GREEN=$'\e[38;5;114m'
BG_ORANGE=$'\e[48;5;208m'
BG_DARK=$'\e[48;5;236m'
HIDE_CURSOR=$'\e[?25l'
SHOW_CURSOR=$'\e[?25h'

SPINNER=("⣾" "⣽" "⣻" "⢿" "⡿" "⣟" "⣯" "⣷")
SPIN_I=0

# ── State ────────────────────────────────────────────────────────────────────
declare -a T_NAME=() T_STATUS=() T_MSG=() T_LOG=() T_SF=() T_PID=() T_ROW=() T_DETAIL=() T_POLL=()
TMPFILES=()
NEXT_ROW=0    # next available display row
NEED_FULL_REDRAW=0

CLEANED_UP=false

cleanup() {
    $CLEANED_UP && return
    CLEANED_UP=true

    # Kill background workers
    local pid
    for pid in "${T_PID[@]+"${T_PID[@]}"}"; do
        [[ -n "$pid" ]] && kill "$pid" 2>/dev/null
    done
    # Brief wait — don't hang forever
    for pid in "${T_PID[@]+"${T_PID[@]}"}"; do
        [[ -n "$pid" ]] && wait "$pid" 2>/dev/null
    done

}

on_interrupt() {
    # Snapshot task state before cleanup kills workers
    local -a snap_name=("${T_NAME[@]+"${T_NAME[@]}"}")
    local -a snap_status=("${T_STATUS[@]+"${T_STATUS[@]}"}")
    local -a snap_msg=("${T_MSG[@]+"${T_MSG[@]}"}")
    local -a snap_log=("${T_LOG[@]+"${T_LOG[@]}"}")

    # Check which tasks actually errored (have ERR: in status file)
    local -a snap_sf=("${T_SF[@]+"${T_SF[@]}"}")
    local i
    for ((i=0; i<${#snap_name[@]}; i++)); do
        local line; line=$(head -1 "${snap_sf[$i]}" 2>/dev/null) || true
        if [[ "${line%%:*}" == "ERR" ]]; then
            snap_status[$i]="error"
            snap_msg[$i]="${line#*:}"
        fi
    done

    cleanup

    # Write report directly to /dev/tty — only show genuinely failed tasks
    {
        if [[ $NEXT_ROW -gt 0 ]]; then
            printf '\e[%d;1H\e[2K' "$((NEXT_ROW + 2))"
        fi
        printf '%s' "$SHOW_CURSOR"

        local had_errors=false
        for ((i=0; i<${#snap_name[@]}; i++)); do
            [[ "${snap_status[$i]}" == "error" ]] && had_errors=true
        done

        if $had_errors; then
            printf '\n  %s%sErrors:%s\n' "$RED" "$BOLD" "$RST"
            for ((i=0; i<${#snap_name[@]}; i++)); do
                [[ "${snap_status[$i]}" != "error" ]] && continue
                printf '\n  %s%s── %s ──%s\n' "$RED" "$BOLD" "${snap_name[$i]}" "$RST"
                if [[ -s "${snap_log[$i]}" ]]; then
                    tail -30 "${snap_log[$i]}" | while IFS= read -r l; do
                        printf '  %s%s%s\n' "$DIM" "$l" "$RST"
                    done
                else
                    printf '  %s(no log output)%s\n' "$DIM" "$RST"
                fi
            done
        fi
        printf '\n'
    } >/dev/tty 2>/dev/null
    exit 130
}

on_exit() {
    cleanup
    # Always restore cursor visibility on exit
    printf '%s' "$SHOW_CURSOR" >/dev/tty 2>/dev/null
    # Remove tmpfiles last — after error reports have read them
    local f
    for f in "${TMPFILES[@]+"${TMPFILES[@]}"}"; do rm -f "$f" 2>/dev/null; done
}
trap on_exit EXIT
trap on_interrupt INT TERM
trap 'NEED_FULL_REDRAW=1' WINCH

# ── Drawing ──────────────────────────────────────────────────────────────────

BUF=""
buf()     { BUF+="$*"; }
buf_goto(){ BUF+=$'\e['"$1"';1H'; }
buf_clr() { BUF+=$'\e[2K'; }
flush()   { printf '%s' "$BUF"; BUF=""; }

cached_cols=80
refresh_cols() { cached_cols=$(tput cols 2>/dev/null || echo 80); }

rule_str() {
    local out="$DARK"
    local i; for ((i=0; i<cached_cols; i++)); do out+="─"; done
    out+="$RST"
    printf '%s' "$out"
}

render_header() {
    buf_goto 1; buf_clr; buf "$(rule_str)"
    buf_goto 2; buf_clr
    buf "  ${BG_DARK}${ORANGE} ▌${RST} ${BOLD}${WHITE}OrbitMines${RST} ${GRAY}Minecraft${RST}"
    buf_goto 3; buf_clr; buf "$(rule_str)"
    buf_goto 4; buf_clr
}

# ── Format helpers ───────────────────────────────────────────────────────────

fmt_bytes() {
    local b=$1
    if   ((b >= 1073741824)); then printf '%.1f GB' "$(echo "scale=1; $b/1073741824" | bc)"
    elif ((b >= 1048576));    then printf '%.1f MB' "$(echo "scale=1; $b/1048576" | bc)"
    elif ((b >= 1024));       then printf '%.0f KB' "$(echo "scale=0; $b/1024" | bc)"
    else printf '%d B' "$b"; fi
}

fmt_time() {
    local s=$1
    if   ((s >= 3600)); then printf '%dh %dm' $((s/3600)) $(((s%3600)/60))
    elif ((s >= 60));   then printf '%dm %ds' $((s/60)) $((s%60))
    else printf '%ds' "$s"; fi
}

bar_str() {
    local pct=$1 w=$2
    local fill=$(( pct * w / 100 )) gap=$(( w - pct * w / 100 ))
    local out="${BG_ORANGE}${BOLD}"
    local i; for ((i=0; i<fill; i++)); do out+=" "; done
    out+="${RST}${BG_DARK}"
    for ((i=0; i<gap; i++)); do out+=" "; done
    out+="$RST"
    printf '%s' "$out"
}

# ── Task registry ───────────────────────────────────────────────────────────

new_task() {
    local name=$1 poll_fn=$2
    local i=${#T_NAME[@]}
    local log; log=$(mktemp); TMPFILES+=("$log")
    local sf;  sf=$(mktemp);  TMPFILES+=("$sf")

    T_NAME+=("$name")
    T_STATUS+=("run")
    T_MSG+=("Waiting...")
    T_DETAIL+=("")
    T_LOG+=("$log")
    T_SF+=("$sf")
    T_PID+=("")
    T_POLL+=("$poll_fn")
    T_ROW+=("$NEXT_ROW")

    NEXT_ROW=$((NEXT_ROW + 3))
}

# Start a task's worker (call after new_task)
start_task() {
    local i=$1
    T_MSG[$i]="Starting..."
    # Worker is launched by caller, which sets T_PID[$i]
}

render_task() {
    local i=$1
    local row=${T_ROW[$i]}

    local icon color
    case "${T_STATUS[$i]}" in
        run)   icon="${SPINNER[$SPIN_I]}"; color="$ORANGE" ;;
        done)  icon="✓"; color="$GREEN" ;;
        error) icon="✗"; color="$RED" ;;
    esac

    buf_goto "$row"; buf_clr
    buf "  ${color}${BOLD}${icon}${RST}  ${WHITE}${BOLD}${T_NAME[$i]}${RST}"

    buf_goto $((row+1)); buf_clr
    local msg="${T_MSG[$i]}"
    local mx=$((cached_cols - 6))
    ((${#msg} > mx)) && msg="${msg:0:$mx}"
    buf "     ${GRAY}${msg}${RST}"

    buf_goto $((row+2)); buf_clr
    [[ -n "${T_DETAIL[$i]}" ]] && buf "${T_DETAIL[$i]}"
}


render_frame() {
    refresh_cols
    BUF=""

    if ((NEED_FULL_REDRAW)); then
        # Full clear on resize — removes all stale content
        buf $'\e[2J'
        NEED_FULL_REDRAW=0
    fi

    render_header
    for ((i=0; i<${#T_NAME[@]}; i++)); do render_task "$i"; done
    buf_goto "$NEXT_ROW"; buf_clr; buf "$(rule_str)"

    flush
}

# ─────────────────────────────────────────────────────────────────────────────
# Workers  (background subshells, communicate via status files)
# ─────────────────────────────────────────────────────────────────────────────

worker_worlds() {
    local sf=$1 log=$2
    exec >>"$log" 2>&1
    set +e

    local need_dl=true
    if [[ -f "$WORLDS_ZIP" ]]; then
        local zs; zs=$(stat -c%s "$WORLDS_ZIP" 2>/dev/null || echo 0)
        ((zs > 40000000000)) && need_dl=false
    fi

    if $need_dl; then
        echo "DL:0" > "$sf"
        curl -fSL -o "$WORLDS_ZIP" "$WORLDS_URL" &
        local cpid=$!
        while kill -0 "$cpid" 2>/dev/null; do
            [[ -f "$WORLDS_ZIP" ]] && echo "DL:$(stat -c%s "$WORLDS_ZIP" 2>/dev/null || echo 0)" > "$sf"
            sleep 0.5
        done
        if ! wait "$cpid"; then
            echo "ERR:Download failed — check connection" > "$sf"; exit 1
        fi
        echo "ST:Download complete, extracting..." > "$sf"
    fi

    echo "ST:Counting archive entries..." > "$sf"
    local total; total=$(unzip -Z1 "$WORLDS_ZIP" | wc -l)

    local unzip_out; unzip_out=$(mktemp)
    unzip -o "$WORLDS_ZIP" -d "$ARCHIVE_DIR" > "$unzip_out" 2>&1 &
    local upid=$!
    while kill -0 "$upid" 2>/dev/null; do
        local c; c=$(wc -l < "$unzip_out" 2>/dev/null || echo 0)
        echo "EX:$c:$total" > "$sf"
        sleep 0.5
    done
    local rc=0; wait "$upid" || rc=$?
    rm -f "$unzip_out"
    if ((rc != 0)); then
        echo "ERR:Extraction failed" > "$sf"; exit 1
    fi
    # Zip contains worlds/ subfolder — move to WORLDS_DIR if names differ
    local extracted="$ARCHIVE_DIR/worlds"
    if [[ "$extracted" != "$WORLDS_DIR" && -d "$extracted" ]]; then
        rm -rf "$WORLDS_DIR"
        mv "$extracted" "$WORLDS_DIR"
    fi

    echo "OK:" > "$sf"
}

worker_spigot() {
    local sf=$1 log=$2
    exec >>"$log" 2>&1
    set +e
    cd "$SPIGOT_DIR"

    echo "ST:Downloading BungeeCord..." > "$sf"
    if ! curl -fsSL -o BungeeCord.jar "$BUNGEECORD_URL"; then
        echo "ERR:Failed to download BungeeCord" > "$sf"; exit 1
    fi

    echo "ST:Downloading BuildTools..." > "$sf"
    if ! curl -fsSL -o BuildTools.jar "$BUILDTOOLS_URL"; then
        echo "ERR:Failed to download BuildTools" > "$sf"; exit 1
    fi

    local n=${#SPIGOT_VERSIONS[@]} j=0
    for v in "${SPIGOT_VERSIONS[@]}"; do
        j=$((j+1))
        if [[ -f "spigot-${v}.jar" ]]; then
            echo "ST:Spigot ${v} already built ($j/$n)" > "$sf"; continue
        fi
        echo "ST:Building Spigot ${v} ($j/$n)..." > "$sf"
        if ! java -jar BuildTools.jar --rev "$v"; then
            echo "ERR:BuildTools failed for ${v}" > "$sf"; exit 1
        fi
    done

    echo "OK:" > "$sf"
}

worker_compile() {
    local sf=$1 log=$2
    exec >>"$log" 2>&1
    set +e

    echo "ST:Compiling archive library..." > "$sf"
    if ! (cd "$REMASTERED_DIR/archive" && mvn clean install); then
        echo "ERR:archive library build failed" > "$sf"; exit 1
    fi

    echo "ST:Compiling BungeeCord plugin..." > "$sf"
    if ! (cd "$REMASTERED_DIR/bungeecord" && mvn clean install); then
        echo "ERR:BungeeCord plugin build failed" > "$sf"; exit 1
    fi
    cp "$REMASTERED_DIR/bungeecord/target/bungeecord-1.0-SNAPSHOT-jar-with-dependencies.jar" \
       "$PLUGINS_DIR/archive-bungeecord.jar"

    echo "ST:Compiling Spigot plugin..." > "$sf"
    if ! (cd "$REMASTERED_DIR/spigot" && mvn clean install); then
        echo "ERR:Spigot plugin build failed" > "$sf"; exit 1
    fi
    cp "$REMASTERED_DIR/spigot/target/spigot-1.0-SNAPSHOT-jar-with-dependencies.jar" \
       "$PLUGINS_DIR/archive-spigot.jar"

    echo "OK:" > "$sf"
}

# ── Pollers ──────────────────────────────────────────────────────────────────

poll_worlds() {
    local i=$1 sf=$2
    local line; line=$(head -1 "$sf" 2>/dev/null) || return
    local k="${line%%:*}" v="${line#*:}"

    case "$k" in
        DL)
            local cur=${v:-0} pct=0
            ((WORLDS_ZIP_SIZE > 0 && cur > 0)) && pct=$((cur * 100 / WORLDS_ZIP_SIZE))
            ((pct > 100)) && pct=100
            T_MSG[$i]="Downloading  $(fmt_bytes "$cur") / $(fmt_bytes $WORLDS_ZIP_SIZE)"
            local bw=$((cached_cols - 16)); ((bw < 10)) && bw=10
            T_DETAIL[$i]="     $(bar_str "$pct" "$bw")  ${DIM}${GRAY}${pct}%${RST}"
            ;;
        EX)
            local c="${v%%:*}" total="${v#*:}"
            c=${c:-0}; total=${total:-1}
            local pct=0
            ((total > 0 && c > 0)) && pct=$((c * 100 / total))
            ((pct > 100)) && pct=100
            T_MSG[$i]="Extracting  ${c} / ${total} files"
            local bw=$((cached_cols - 16)); ((bw < 10)) && bw=10
            T_DETAIL[$i]="     $(bar_str "$pct" "$bw")  ${DIM}${GRAY}${pct}%${RST}"
            ;;
        ST)  T_MSG[$i]="$v"; T_DETAIL[$i]="" ;;
        OK)  T_MSG[$i]="$WORLDS_EXPECTED_COUNT worlds ready"; T_DETAIL[$i]="" ;;
        ERR) T_MSG[$i]="$v"; T_DETAIL[$i]="" ;;
    esac
}

poll_spigot() {
    local i=$1 sf=$2
    local line; line=$(head -1 "$sf" 2>/dev/null) || return
    local k="${line%%:*}" v="${line#*:}"
    case "$k" in
        ST)  T_MSG[$i]="$v" ;;
        OK)  T_MSG[$i]="Spigot + BungeeCord ready" ;;
        ERR) T_MSG[$i]="$v" ;;
    esac
}

poll_compile() {
    local i=$1 sf=$2
    local line; line=$(head -1 "$sf" 2>/dev/null) || return
    local k="${line%%:*}" v="${line#*:}"
    case "$k" in
        ST)  T_MSG[$i]="$v" ;;
        OK)  T_MSG[$i]="Plugins compiled" ;;
        ERR) T_MSG[$i]="$v" ;;
    esac
}

# ─────────────────────────────────────────────────────────────────────────────
# Task loop
# ─────────────────────────────────────────────────────────────────────────────

# Poll all registered tasks, finish any whose pid has exited.
# Returns 0 if any task is still running, 1 if all done.
tick_tasks() {
    local alive=false
    for ((i=0; i<${#T_NAME[@]}; i++)); do
        [[ "${T_STATUS[$i]}" != "run" ]] && continue
        local pid="${T_PID[$i]}"
        # Not yet started (empty pid = pending)
        [[ -z "$pid" ]] && { alive=true; continue; }

        # Poll status file
        "${T_POLL[$i]}" "$i" "${T_SF[$i]}"

        if ! kill -0 "$pid" 2>/dev/null; then
            local rc=0; wait "$pid" || rc=$?
            "${T_POLL[$i]}" "$i" "${T_SF[$i]}"
            if ((rc == 0)); then T_STATUS[$i]="done"; else T_STATUS[$i]="error"; fi
        else
            alive=true
        fi
    done

    SPIN_I=$(( (SPIN_I + 1) % ${#SPINNER[@]} ))
    render_frame
    $alive && return 0 || return 1
}

# Spin until all tasks are done.
await_all() {
    while tick_tasks; do
        sleep 0.2
    done
}


# ─────────────────────────────────────────────────────────────────────────────
# Checks
# ─────────────────────────────────────────────────────────────────────────────

worlds_needed() {
    [[ ! -d "$WORLDS_DIR" ]] && return 0
    local c; c=$(find "$WORLDS_DIR" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l)
    ((c < 400)) && return 0
    return 1
}

spigot_needed() {
    [[ ! -f "$SPIGOT_DIR/BungeeCord.jar" ]] && return 0
    for v in "${SPIGOT_VERSIONS[@]}"; do
        [[ ! -f "$SPIGOT_DIR/spigot-${v}.jar" ]] && return 0
    done
    return 1
}

compile_needed() {
    [[ ! -f "$PLUGINS_DIR/archive-bungeecord.jar" ]] && return 0
    [[ ! -f "$PLUGINS_DIR/archive-spigot.jar" ]] && return 0
    return 1
}

# ─────────────────────────────────────────────────────────────────────────────
# minecraft run
# ─────────────────────────────────────────────────────────────────────────────

cmd_run() {
    local force_compile=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --compile) force_compile=true; shift ;;
            *) printf '%s%sUnknown option: %s%s\n' "$RED" "$BOLD" "$1" "$RST"; exit 1 ;;
        esac
    done

    local t0; t0=$(date +%s)
    local need_worlds=false need_spigot=false need_compile=false

    worlds_needed && need_worlds=true
    spigot_needed && need_spigot=true
    $force_compile && need_compile=true
    ! $force_compile && compile_needed && need_compile=true

    # If nothing to do, skip straight to launch
    if ! $need_worlds && ! $need_spigot && ! $need_compile; then
        printf '%s' "$SHOW_CURSOR"
        # Jump to launch
        cp "$SPIGOT_DIR/BungeeCord.jar" "$SERVERS_DIR/BungeeCord/server.jar"
        cp "$PLUGINS_DIR/archive-bungeecord.jar" "$SERVERS_DIR/BungeeCord/plugins/archive-bungeecord.jar"

        refresh_cols
        printf '%s' "$(rule_str)"
        printf '\n  %s%s▸%s %sStarting BungeeCord%s\n' "$ORANGE" "$BOLD" "$RST" "$WHITE" "$RST"
        printf '%s' "$(rule_str)"
        printf '\n\n'

        cd "$SERVERS_DIR/BungeeCord"
        exec java -jar server.jar
    fi

    printf '%s\e[2J' "$HIDE_CURSOR"   # hide cursor + full clear
    refresh_cols
    NEXT_ROW=5

    local si=-1 wi=-1 ci=-1
    local compile_started=false

    # ── Register all tasks up front ──────────────────────────────────────

    if $need_spigot; then
        new_task "Install Spigot" poll_spigot
        si=$(( ${#T_NAME[@]} - 1 ))
        worker_spigot "${T_SF[$si]}" "${T_LOG[$si]}" &
        T_PID[$si]=$!
    fi

    if $need_worlds; then
        new_task "Download worlds" poll_worlds
        wi=$(( ${#T_NAME[@]} - 1 ))
        worker_worlds "${T_SF[$wi]}" "${T_LOG[$wi]}" &
        T_PID[$wi]=$!
    fi

    if $need_compile; then
        # Compile task — registered now but only started once spigot is done
        new_task "Compile plugins" poll_compile
        ci=$(( ${#T_NAME[@]} - 1 ))

        if ! $need_spigot; then
            # Spigot already installed, start compile immediately
            worker_compile "${T_SF[$ci]}" "${T_LOG[$ci]}" &
            T_PID[$ci]=$!
            T_MSG[$ci]="Starting..."
            compile_started=true
        fi
    fi

    # ── Unified loop: tick all tasks, start compile when spigot finishes ─
    render_frame
    while true; do
        # Check if spigot just finished and compile hasn't started
        if ! $compile_started && ((ci >= 0)) && ((si >= 0)); then
            if [[ "${T_STATUS[$si]}" == "done" ]]; then
                worker_compile "${T_SF[$ci]}" "${T_LOG[$ci]}" &
                T_PID[$ci]=$!
                T_MSG[$ci]="Starting..."
                compile_started=true
            elif [[ "${T_STATUS[$si]}" == "error" ]]; then
                T_STATUS[$ci]="error"
                T_MSG[$ci]="Skipped — Install Spigot failed"
                compile_started=true
            fi
        fi

        tick_tasks || break
        sleep 0.2
    done

    # ── Check for errors ─────────────────────────────────────────────────
    local had_errors=false
    for ((i=0; i<${#T_NAME[@]}; i++)); do
        [[ "${T_STATUS[$i]}" == "error" ]] && had_errors=true
    done

    if $had_errors; then
        # Position cursor below the frame
        printf '\e[%d;1H' "$((NEXT_ROW + 1))"
        printf '\n  %s%sErrors:%s\n' "$RED" "$BOLD" "$RST"
        for ((i=0; i<${#T_NAME[@]}; i++)); do
            [[ "${T_STATUS[$i]}" != "error" ]] && continue
            printf '\n  %s%s── %s ──%s\n' "$RED" "$BOLD" "${T_NAME[$i]}" "$RST"
            if [[ -s "${T_LOG[$i]}" ]]; then
                tail -30 "${T_LOG[$i]}" | while IFS= read -r l; do
                    printf '  %s%s%s\n' "$DIM" "$l" "$RST"
                done
            else
                printf '  %s(no log output)%s\n' "$DIM" "$RST"
            fi
        done
        printf '\n%s' "$SHOW_CURSOR"
        exit 1
    fi

    # ── Launch ───────────────────────────────────────────────────────────
    local elapsed=$(( $(date +%s) - t0 ))
    printf '\e[%d;1H\e[2K' "$((NEXT_ROW + 1))"
    printf '  %s%sReady in %s%s\n\n' "$GRAY" "$DIM" "$(fmt_time $elapsed)" "$RST"
    printf '%s' "$SHOW_CURSOR"

    cp "$SPIGOT_DIR/BungeeCord.jar" "$SERVERS_DIR/BungeeCord/server.jar"
    cp "$PLUGINS_DIR/archive-bungeecord.jar" "$SERVERS_DIR/BungeeCord/plugins/archive-bungeecord.jar"

    refresh_cols
    printf '%s' "$(rule_str)"
    printf '\n  %s%s▸%s %sStarting BungeeCord%s\n' "$ORANGE" "$BOLD" "$RST" "$WHITE" "$RST"
    printf '%s' "$(rule_str)"
    printf '\n\n'

    cd "$SERVERS_DIR/BungeeCord"
    exec java -jar server.jar
}

# ─────────────────────────────────────────────────────────────────────────────
# Entry
# ─────────────────────────────────────────────────────────────────────────────

usage() {
    printf '\n'
    printf '  %s%s ▌%s %sOrbitMines%s %sCLI%s\n\n' \
        "$BG_DARK" "$ORANGE" "$RST" "$BOLD$WHITE" "$RST" "$GRAY" "$RST"
    printf '  %sUsage:%s  ./orbitmines <domain> <command>\n\n' "$ORANGE" "$RST"
    printf '  %sCommands:%s\n' "$ORANGE" "$RST"
    printf '    %sminecraft run%s             Setup & start the Minecraft servers\n' "$WHITE" "$RST"
    printf '    %sminecraft run --compile%s   Force recompile plugins\n\n' "$WHITE" "$RST"
}

main() {
    if [[ $# -lt 2 ]]; then usage; exit 1; fi
    case "$1" in
        minecraft)
            case "$2" in
                run) shift 2; cmd_run "$@" ;;
                *)   printf '%s%sUnknown command: %s%s\n' "$RED" "$BOLD" "$2" "$RST"; usage; exit 1 ;;
            esac ;;
        *)
            printf '%s%sUnknown domain: %s%s\n' "$RED" "$BOLD" "$1" "$RST"; usage; exit 1 ;;
    esac
}

main "$@"
