eb de spawner van mij uitgebreid, maar is voor niemand bereikbaar"]}},"6":{"==":"org.bukkit.inventory.ItemStack","type":"DIAMOND_PICKAXE","damage":1144,"meta":{"==":"ItemMeta","meta-type":"UNSPECIFIC","enchants":{"DURABILITY":3,"DIG_SPEED":4}}},"5":{"==":"org.bukkit.inventory.ItemStack","type":"IRON_SPADE","damage":174},"31":{"==":"org.bukkit.inventory.ItemStack","type":"STICK","amount":5},"4":{"==":"org.bukkit.inventory.ItemStack","type":"BREAD","amount":27},"9":{"==":"org.bukkit.inventory.ItemStack","type":"ARROW","amount":3},"8":{"==":"org.bukkit.inventory.ItemStack","type":"DIAMOND_SWORD","damage":1394,"meta":{"==":"ItemMeta","meta-type":"UNSPECIFIC","enchants":{"DAMAGE_UNDEAD":1}}}},"bedSpawnLocation":{"ya":0.0,"wo":"SurvivalWorld","pi":0.0,"z":-119.0,"y":60.0,"x":-1571.0},"stats":{"ra":"300","ex":"3.4188967","hp":"20","txp":"0","fl":"20","el":"0","ma":"300","sa":"3.0","xp":"0.0","ft":"-20","fd":"0.0"}}}